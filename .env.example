# Google OAuth（匯入班表用，必填才能讀取試算表）
# 到 Google Cloud Console → API 和服務 → 憑證 → 建立 OAuth 2.0 用戶端 ID（網頁應用程式）
# 已授權的 JavaScript 來源請加入 http://localhost:3000
VITE_GOOGLE_CLIENT_ID=你的用戶端ID.apps.googleusercontent.com

# Firebase（雲端備份用，選填；不設定也能使用匯入班表）
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
